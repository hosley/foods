{
	"$id": "https://example.com/recipe-details.schema.json",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"properties": {
		"id": { "type": "string" },
		"shoppingList": {
			"items": {
				"properties": {
					"displayName": {
						"description": "e.g., 'Boneless skinless chicken breasts'",
						"type": "string"
					},
					"ingredientId": {
						"description": "Normalized ID for aggregating meal plans",
						"type": "string"
					},
					"quantity": { "type": "number" },
					"unit": {
						"description": "e.g., 'lbs', 'cups', 'tbsp', 'cloves'",
						"type": "string"
					}
				},
				"required": ["ingredientId", "displayName", "quantity", "unit"],
				"type": "object"
			},
			"type": "array"
		},
		"steps": {
			"items": {
				"properties": {
					"equipmentUsed": {
						"items": { "type": "string" },
						"type": "array"
					},
					"ingredientsUsed": {
						"items": {
							"properties": {
								"ingredientId": { "type": "string" },
								"quantity": { "type": "number" },
								"unit": { "type": "string" }
							},
							"required": ["ingredientId", "quantity", "unit"],
							"type": "object"
						},
						"type": "array"
					},
					"instruction": { "description": "Freeform text", "type": "string" },
					"stepNumber": { "type": "integer" },
					"timeMinutes": {
						"description": "Approximate time if it is a timed step",
						"type": "integer"
					}
				},
				"required": ["stepNumber", "instruction"],
				"type": "object"
			},
			"type": "array"
		}
	},
	"required": ["id", "shoppingList", "steps"],
	"title": "RecipeDetails",
	"type": "object"
}
