{
	"$id": "https://example.com/recipe-summary.schema.json",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"items": {
		"properties": {
			"cuisine": { "type": "string" },
			"id": {
				"description": "Unique identifier, also the filename of the details JSON",
				"type": "string"
			},
			"primaryProtein": {
				"description": "e.g., 'Chicken', 'Beef', 'Vegetarian'",
				"type": "string"
			},
			"searchableEquipment": {
				"description": "Normalized equipment names (e.g., 'blender', 'dutch oven')",
				"items": { "type": "string" },
				"type": "array"
			},
			"searchableIngredients": {
				"description": "Normalized names only (e.g., 'garlic', 'chicken breast') for search",
				"items": { "type": "string" },
				"type": "array"
			},
			"title": { "type": "string" },
			"totalTimeMinutes": { "type": "integer" }
		},
		"required": ["id", "title", "cuisine", "totalTimeMinutes"],
		"type": "object"
	},
	"title": "RecipeSummaryIndex",
	"type": "array"
}
