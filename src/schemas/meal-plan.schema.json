{
	"$id": "https://example.com/meal-plan.schema.json",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"properties": {
		"aggregatedShoppingList": {
			"items": {
				"properties": {
					"ingredientId": { "type": "string" },
					"totalQuantity": { "type": "number" },
					"unit": { "type": "string" }
				},
				"required": ["ingredientId", "totalQuantity", "unit"],
				"type": "object"
			},
			"type": "array"
		},
		"selectedRecipeIds": {
			"items": { "type": "string" },
			"type": "array"
		},
		"weekOf": {
			"format": "date",
			"type": "string"
		}
	},
	"required": ["weekOf", "selectedRecipeIds", "aggregatedShoppingList"],
	"title": "WeeklyMealPlan",
	"type": "object"
}
