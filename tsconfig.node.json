{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"lib": ["ES2022"],
		"module": "ESNext",

		/* Bundler mode */
		"moduleResolution": "bundler",
		"noEmit": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		/* Linting */
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node"]
	},
	"include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
